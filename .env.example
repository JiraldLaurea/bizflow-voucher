# --- Database (PostgreSQL / Supabase) ---
# For Supabase use the "Connection string" (session pooler for migrations, transaction pooler for app).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bizflow?schema=public"

# --- Auth ---
# 32+ char random secret used to sign session JWTs. Generate: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-secret-string"

# --- App ---
# Public base URL, used to build voucher claim links and QR targets.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- SMS provider ---
# Options: "mock" (logs only, default for dev), "semaphore", "twilio"
SMS_PROVIDER="mock"

# Semaphore (PH aggregator) — https://semaphore.co
SEMAPHORE_API_KEY=""
SEMAPHORE_SENDER_NAME=""

# Twilio (fallback)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# Movider (Philippines) — https://movider.net
# Get your API key & secret from the Movider dashboard
SMS_API_KEY=SBL62m5gArTne0Sxxf6cn1uFncVvAB
SMS_API_SECRET=yo-sNy8-HHutgabkdnPH3dVYF0GHJC
